<Window x:Class="RfxTiming.Smis.Receiver.Views.ConnectionSettingsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="接続設定 — MOLA_Timing-Receiver"
        Width="480" Height="360"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        FontFamily="Segoe UI, Yu Gothic UI, Meiryo UI"
        FontSize="13"
        TextOptions.TextFormattingMode="Display">

    <Border Padding="20" Background="{StaticResource Background.Window}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0"
                       Text="SMIS サーバー接続設定"
                       FontSize="18" FontWeight="SemiBold"
                       Margin="0,0,0,16" />

            <StackPanel Grid.Row="1">
                <TextBlock Text="ホスト名 / IP アドレス"
                           Foreground="{StaticResource Foreground.Secondary}"
                           FontSize="12" />
                <TextBox x:Name="HostBox" Margin="0,4,0,12" />

                <TextBlock Text="ポート"
                           Foreground="{StaticResource Foreground.Secondary}"
                           FontSize="12" />
                <TextBox x:Name="PortBox" Margin="0,4,0,12" />

                <CheckBox x:Name="AutoReconnectBox"
                          Content="切断時に自動再接続する (指数バックオフ)"
                          Foreground="{StaticResource Foreground.Primary}"
                          Margin="0,8,0,0" />

                <TextBlock Margin="0,16,0,0"
                           Foreground="{StaticResource Foreground.Secondary}"
                           TextWrapping="Wrap"
                           FontSize="11">
                    <Run Text="• 計時室 LAN 内で MOLA サーバーへ直結する場合はそのまま MOLA 側で指定された IP/Port を入力。" /><LineBreak />
                    <Run Text="• 開発機の MOLA_Timing-VirtualServer に接続する場合は 127.0.0.1 (または LAN IP) と VirtualServer 側で起動したポート。" />
                </TextBlock>
            </StackPanel>

            <StackPanel Grid.Row="2"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Margin="0,16,0,0">
                <Button Content="キャンセル"
                        Width="100" Height="32"
                        IsCancel="True" />
                <Button Content="OK"
                        Width="100" Height="32"
                        Margin="8,0,0,0"
                        IsDefault="True"
                        Click="OnOkClick" />
            </StackPanel>
        </Grid>
    </Border>
</Window>
