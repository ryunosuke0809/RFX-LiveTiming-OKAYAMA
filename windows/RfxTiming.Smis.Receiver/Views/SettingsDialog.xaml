<Window x:Class="RfxTiming.Smis.Receiver.Views.SettingsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="設定"
        Width="620" Height="520"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        FontFamily="Segoe UI, Yu Gothic UI, Meiryo UI"
        FontSize="13"
        Background="White"
        Foreground="Black"
        TextElement.Foreground="Black"
        TextOptions.TextFormattingMode="Display">

    <Window.Resources>

        <SolidColorBrush x:Key="Dialog.Text" Color="Black" />
        <SolidColorBrush x:Key="Dialog.SubText" Color="#1A1F2E" />
        <SolidColorBrush x:Key="Dialog.Surface" Color="White" />
        <SolidColorBrush x:Key="Dialog.SurfaceAlt" Color="#F0F2F5" />
        <SolidColorBrush x:Key="Dialog.Border" Color="#C9CDD3" />
        <SolidColorBrush x:Key="Dialog.Accent" Color="#1F6FEB" />
        <SolidColorBrush x:Key="Dialog.AccentHover" Color="#3A82F0" />
        <SolidColorBrush x:Key="Dialog.TabActive" Color="White" />
        <SolidColorBrush x:Key="Dialog.TabInactive" Color="#E1E4E8" />

        <!--
          App.xaml の dark テーマ用 SystemColors override をこのダイアログ内では取り消す。
          TabItem / Button / ContentPresenter 等の既定テンプレートが SystemColors を参照しており、
          ここをライト色に戻さないと unselected タブ / Cancel ボタン文字が薄く見えてしまう。
        -->
        <SolidColorBrush x:Key="{x:Static SystemColors.ControlBrushKey}" Color="White" />
        <SolidColorBrush x:Key="{x:Static SystemColors.ControlTextBrushKey}" Color="Black" />
        <SolidColorBrush x:Key="{x:Static SystemColors.GrayTextBrushKey}" Color="#5C636F" />
        <SolidColorBrush x:Key="{x:Static SystemColors.WindowBrushKey}" Color="White" />
        <SolidColorBrush x:Key="{x:Static SystemColors.WindowTextBrushKey}" Color="Black" />
        <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#1F6FEB" />
        <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="White" />
        <SolidColorBrush x:Key="{x:Static SystemColors.InactiveCaptionBrushKey}" Color="White" />
        <SolidColorBrush x:Key="{x:Static SystemColors.InactiveCaptionTextBrushKey}" Color="Black" />
        <SolidColorBrush x:Key="{x:Static SystemColors.MenuBrushKey}" Color="White" />
        <SolidColorBrush x:Key="{x:Static SystemColors.MenuTextBrushKey}" Color="Black" />

        <Style TargetType="{x:Type TextBlock}">
            <Setter Property="Foreground" Value="Black" />
        </Style>
        <Style TargetType="{x:Type Label}">
            <Setter Property="Foreground" Value="Black" />
        </Style>

        <Style TargetType="{x:Type TextBox}">
            <Setter Property="Foreground" Value="Black" />
            <Setter Property="Background" Value="White" />
            <Setter Property="BorderBrush" Value="{StaticResource Dialog.Border}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="6,3" />
            <Setter Property="CaretBrush" Value="Black" />
            <Setter Property="SelectionBrush" Value="{StaticResource Dialog.Accent}" />
        </Style>

        <Style TargetType="{x:Type CheckBox}">
            <Setter Property="Foreground" Value="Black" />
            <Setter Property="Background" Value="White" />
            <Setter Property="BorderBrush" Value="{StaticResource Dialog.Border}" />
        </Style>

        <!--
          TabControl/TabItem は完全に独自テンプレートにして、
          選択 / 非選択どちらでもラベル文字が黒で確実に読めるようにする。
        -->
        <Style TargetType="{x:Type TabControl}">
            <Setter Property="Background" Value="White" />
            <Setter Property="BorderBrush" Value="{StaticResource Dialog.Border}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="0" />
        </Style>
        <Style TargetType="{x:Type TabItem}">
            <Setter Property="Foreground" Value="Black" />
            <Setter Property="Background" Value="{StaticResource Dialog.TabInactive}" />
            <Setter Property="BorderBrush" Value="{StaticResource Dialog.Border}" />
            <Setter Property="Padding" Value="18,7" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type TabItem}">
                        <Border x:Name="TabBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{StaticResource Dialog.Border}"
                                BorderThickness="1,1,1,0"
                                CornerRadius="4,4,0,0"
                                Margin="0,0,2,0"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter ContentSource="Header"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              TextElement.Foreground="Black" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="TabBorder" Property="Background" Value="{StaticResource Dialog.TabActive}" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="TabBorder" Property="Background" Value="#F7F8FA" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="{x:Type Separator}">
            <Setter Property="Background" Value="{StaticResource Dialog.Border}" />
        </Style>

        <!--
          Button は OK / Cancel どちらも独自テンプレート。
          IsCancel を Trigger で扱うと App.xaml の Button.Foreground=White が
          優先されてしまうため、Cancel 用と OK 用を別 x:Key で完全に分ける。
        -->
        <Style x:Key="PrimaryButton" TargetType="{x:Type Button}">
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Background" Value="{StaticResource Dialog.Accent}" />
            <Setter Property="BorderBrush" Value="{StaticResource Dialog.Accent}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="14,6" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              TextElement.Foreground="White" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource Dialog.AccentHover}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecondaryButton" TargetType="{x:Type Button}">
            <Setter Property="Foreground" Value="Black" />
            <Setter Property="Background" Value="{StaticResource Dialog.SurfaceAlt}" />
            <Setter Property="BorderBrush" Value="{StaticResource Dialog.Border}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="14,6" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              TextElement.Foreground="Black" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#E3E7EC" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <DockPanel Margin="14">

        <!-- フッターの OK/Cancel -->
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,14,0,0">
            <Button Content="OK"
                    Style="{StaticResource PrimaryButton}"
                    Width="110" Height="34"
                    IsDefault="True"
                    Click="OnOkClick"
                    Margin="0,0,8,0" />
            <Button Content="キャンセル"
                    Style="{StaticResource SecondaryButton}"
                    Width="110" Height="34"
                    IsCancel="True" />
        </StackPanel>

        <TabControl>
            <!-- 接続 -->
            <TabItem Header="接続">
                <Grid Margin="18">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="170" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="ホスト名 / IP" VerticalAlignment="Center" Margin="0,0,12,8" />
                    <TextBox Grid.Row="0" Grid.Column="1" x:Name="HostBox" Height="28" Margin="0,0,0,8" />

                    <TextBlock Grid.Row="1" Grid.Column="0" Text="ポート" VerticalAlignment="Center" Margin="0,0,12,8" />
                    <TextBox Grid.Row="1" Grid.Column="1" x:Name="PortBox" Width="120" Height="28"
                             HorizontalAlignment="Left" Margin="0,0,0,8" />

                    <TextBlock Grid.Row="2" Grid.Column="0" Text="自動再接続" VerticalAlignment="Center" Margin="0,0,12,8" />
                    <CheckBox Grid.Row="2" Grid.Column="1" x:Name="AutoReconnectBox"
                              Content="切断時に自動で再接続を試みる"
                              VerticalAlignment="Center" Margin="0,0,0,8" />

                    <TextBlock Grid.Row="3" Grid.Column="0" Text="起動時に自動接続" VerticalAlignment="Center" Margin="0,0,12,8" />
                    <CheckBox Grid.Row="3" Grid.Column="1" x:Name="AutoConnectBox"
                              Content="アプリ起動と同時に接続を試みる"
                              VerticalAlignment="Center" Margin="0,0,0,8" />

                    <TextBlock Grid.Row="4" Grid.Column="0" Text="初期リトライ間隔 (ms)" VerticalAlignment="Center" Margin="0,0,12,8" />
                    <TextBox Grid.Row="4" Grid.Column="1" x:Name="InitialRetryBox" Width="120" Height="28"
                             HorizontalAlignment="Left" Margin="0,0,0,8" />

                    <TextBlock Grid.Row="5" Grid.Column="0" Text="最大リトライ間隔 (ms)" VerticalAlignment="Center" Margin="0,0,12,8" />
                    <TextBox Grid.Row="5" Grid.Column="1" x:Name="MaxRetryBox" Width="120" Height="28"
                             HorizontalAlignment="Left" Margin="0,0,0,8" />
                </Grid>
            </TabItem>

            <!-- 表示 -->
            <TabItem Header="表示">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="18">
                        <TextBlock Text="表示するカード / 要素" FontWeight="SemiBold" Margin="0,0,0,12" />

                        <CheckBox x:Name="ShowMessageCountBox" Content="受信メッセージ数カード" Margin="0,0,0,8" />
                        <CheckBox x:Name="ShowMessageRateBox" Content="受信レート (msg/sec) カード" Margin="0,0,0,8" />
                        <CheckBox x:Name="ShowParseErrorsBox" Content="エラー件数カード (パース失敗 / 書込失敗)" Margin="0,0,0,8" />
                        <CheckBox x:Name="ShowLogSizeBox" Content="ログサイズ表示" Margin="0,0,0,8" />
                        <CheckBox x:Name="ShowLastMessagePreviewBox" Content="最終受信メッセージのプレビュー (デバッグ用)" Margin="0,0,0,8" />

                        <Separator Margin="0,12" />

                        <TextBlock Text="ステータスバー" FontWeight="SemiBold" Margin="0,0,0,12" />
                        <CheckBox x:Name="ShowLastReceivedAtInStatusBarBox" Content="最終受信時刻を表示する" Margin="0,0,0,8" />

                        <Separator Margin="0,12" />

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="170" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="アクセントカラー" VerticalAlignment="Center" />
                            <TextBox Grid.Column="1" x:Name="AccentColorBox" Width="180" Height="28"
                                     HorizontalAlignment="Left" />
                        </Grid>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ログ -->
            <TabItem Header="ログ">
                <Grid Margin="18">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="200" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="生 XML ログを出力" VerticalAlignment="Center" Margin="0,0,12,8" />
                    <CheckBox Grid.Row="0" Grid.Column="1" x:Name="EnableRawLogBox"
                              Content="MOLA_INPUT_YYYYMMDD.log を作成" Margin="0,0,0,8" />

                    <TextBlock Grid.Row="1" Grid.Column="0" Text="解析済 JSONL を出力" VerticalAlignment="Center" Margin="0,0,12,8" />
                    <CheckBox Grid.Row="1" Grid.Column="1" x:Name="EnableParsedLogBox"
                              Content="MOLA_INPUT_YYYYMMDD.jsonl を作成" Margin="0,0,0,8" />

                    <TextBlock Grid.Row="2" Grid.Column="0" Text="最大ファイルサイズ (MB)" VerticalAlignment="Center" Margin="0,0,12,8" />
                    <TextBox Grid.Row="2" Grid.Column="1" x:Name="MaxFileSizeBox" Width="120" Height="28"
                             HorizontalAlignment="Left" Margin="0,0,0,8" />

                    <TextBlock Grid.Row="3" Grid.Column="0" Text="USB ミラー出力先" VerticalAlignment="Center" Margin="0,0,12,8" />
                    <TextBox Grid.Row="3" Grid.Column="1" x:Name="UsbMirrorPathBox" Height="28" Margin="0,0,0,8" />
                </Grid>
            </TabItem>

            <!-- クラウド配信 -->
            <TabItem Header="クラウド配信">
                <Grid Margin="18">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="200" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="クラウドへ配信する" VerticalAlignment="Center" Margin="0,0,12,8" />
                    <CheckBox Grid.Row="0" Grid.Column="1" x:Name="CloudEnabledBox"
                              Content="解析済メッセージをクラウドサーバーへ転送" Margin="0,0,0,8" />

                    <TextBlock Grid.Row="1" Grid.Column="0" Text="サーバー URL" VerticalAlignment="Center" Margin="0,0,12,8" />
                    <TextBox Grid.Row="1" Grid.Column="1" x:Name="CloudUrlBox" Height="28" Margin="0,0,0,8" />

                    <TextBlock Grid.Row="2" Grid.Column="0" Text="認証トークン" VerticalAlignment="Center" Margin="0,0,12,8" />
                    <TextBox Grid.Row="2" Grid.Column="1" x:Name="CloudTokenBox" Height="28" Margin="0,0,0,8" />

                    <TextBlock Grid.Row="3" Grid.Column="0" Text="サーキット ID" VerticalAlignment="Center" Margin="0,0,12,8" />
                    <TextBox Grid.Row="3" Grid.Column="1" x:Name="CloudCircuitIdBox" Width="220" Height="28"
                             HorizontalAlignment="Left" Margin="0,0,0,8" />
                </Grid>
            </TabItem>
        </TabControl>
    </DockPanel>
</Window>
