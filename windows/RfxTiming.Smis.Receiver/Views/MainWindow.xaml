<Window x:Class="RfxTiming.Smis.Receiver.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:RfxTiming.Smis.Receiver.ViewModels"
        xmlns:conv="clr-namespace:RfxTiming.Smis.Receiver.ViewModels"
        Title="MOLA_Timing-Receiver"
        Width="1100" Height="680"
        MinWidth="860" MinHeight="540"
        FontFamily="Segoe UI, Yu Gothic UI, Meiryo UI"
        FontSize="13"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType">

    <Window.DataContext>
        <vm:MainViewModel />
    </Window.DataContext>

    <Window.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVisibility" />
    </Window.Resources>

    <DockPanel LastChildFill="True">

        <!-- メニューバー (常に表示するが最小限) -->
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="_File">
                <MenuItem Header="ログフォルダを開く (_L)" Command="{Binding OpenLogsFolderCommand}" />
                <Separator />
                <MenuItem Header="終了 (_X)" Command="{Binding ExitAppCommand}" />
            </MenuItem>
            <MenuItem Header="_Settings">
                <MenuItem Header="設定 (_O)..." Command="{Binding OpenSettingsCommand}" />
            </MenuItem>
            <MenuItem Header="_Help">
                <MenuItem Header="バージョン情報 (_A)..." Command="{Binding ShowAboutCommand}" />
            </MenuItem>
        </Menu>

        <!-- 主要アクションのツールバー -->
        <Border DockPanel.Dock="Top" Background="{StaticResource Background.Panel}" Padding="14,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0"
                        Content="▶ 接続開始"
                        Command="{Binding ConnectCommand}"
                        Padding="20,8" FontWeight="SemiBold" FontSize="14"
                        Margin="0,0,8,0" />
                <Button Grid.Column="1"
                        Content="■ 切断"
                        Command="{Binding DisconnectCommand}"
                        Padding="20,8" FontSize="14" />

                <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center">
                    <Ellipse Width="14" Height="14" Margin="0,0,8,0"
                             Fill="{Binding HeadlineStatusBrush}" />
                    <TextBlock Text="{Binding HeadlineStatusText}"
                               FontSize="14" FontWeight="SemiBold"
                               VerticalAlignment="Center"
                               Foreground="{StaticResource Foreground.Primary}" />
                </StackPanel>

                <Button Grid.Column="4"
                        Content="⚙ 設定"
                        Command="{Binding OpenSettingsCommand}"
                        Padding="14,8" Margin="16,0,0,0" />
            </Grid>
        </Border>

        <!-- ステータスバー -->
        <StatusBar DockPanel.Dock="Bottom">
            <StatusBarItem>
                <StackPanel Orientation="Horizontal">
                    <Ellipse Width="10" Height="10" Margin="0,0,6,0"
                             Fill="{Binding ReceiveStatusBrush}" />
                    <TextBlock Text="{Binding ConnectionEndpointText, StringFormat='接続先: {0}'}"
                               Foreground="{StaticResource Foreground.Secondary}" />
                </StackPanel>
            </StatusBarItem>
            <Separator />
            <StatusBarItem>
                <TextBlock Foreground="{StaticResource Foreground.Secondary}"
                           Visibility="{Binding Display.ShowLastReceivedAtInStatusBar, Converter={StaticResource BoolToVisibility}}">
                    <Run Text="最終受信: " />
                    <Run Text="{Binding LastReceivedAtText}" />
                </TextBlock>
            </StatusBarItem>
            <Separator />
            <StatusBarItem>
                <TextBlock Foreground="{StaticResource Foreground.Secondary}">
                    <Run Text="ログ: " />
                    <Run Text="{Binding LogSizeText}" />
                </TextBlock>
            </StatusBarItem>
            <StatusBarItem HorizontalAlignment="Right">
                <TextBlock Foreground="{StaticResource Foreground.Secondary}" FontSize="11">
                    MOLA_Timing-Receiver v0.1.0
                </TextBlock>
            </StatusBarItem>
        </StatusBar>

        <!-- メイン領域 -->
        <Grid Margin="14">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- 3 ステージのパイプライン LED -->
            <Border Grid.Row="0"
                    Background="{StaticResource Background.Panel}"
                    CornerRadius="8" Padding="20"
                    Visibility="{Binding Display.ShowPipelineDiagram, Converter={StaticResource BoolToVisibility}}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <!-- 受信 -->
                    <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                        <Ellipse Width="44" Height="44" Fill="{Binding ReceiveStatusBrush}">
                            <Ellipse.Effect>
                                <DropShadowEffect Color="Black" Opacity="0.35" BlurRadius="8" ShadowDepth="2" />
                            </Ellipse.Effect>
                        </Ellipse>
                        <TextBlock Text="SMIS 受信" FontSize="13" FontWeight="SemiBold"
                                   HorizontalAlignment="Center" Margin="0,8,0,2" />
                        <TextBlock Text="{Binding ReceiveStatusText}"
                                   FontSize="11" HorizontalAlignment="Center"
                                   Foreground="{StaticResource Foreground.Secondary}" />
                    </StackPanel>

                    <!-- 矢印 -->
                    <TextBlock Grid.Column="1" Text="→" FontSize="22"
                               VerticalAlignment="Center" Foreground="{StaticResource Foreground.Secondary}"
                               Margin="12,0" />

                    <!-- パース -->
                    <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                        <Ellipse Width="44" Height="44" Fill="{Binding ParseStatusBrush}">
                            <Ellipse.Effect>
                                <DropShadowEffect Color="Black" Opacity="0.35" BlurRadius="8" ShadowDepth="2" />
                            </Ellipse.Effect>
                        </Ellipse>
                        <TextBlock Text="パース" FontSize="13" FontWeight="SemiBold"
                                   HorizontalAlignment="Center" Margin="0,8,0,2" />
                        <TextBlock Text="{Binding ParseStatusText}"
                                   FontSize="11" HorizontalAlignment="Center"
                                   Foreground="{StaticResource Foreground.Secondary}" />
                    </StackPanel>

                    <TextBlock Grid.Column="3" Text="→" FontSize="22"
                               VerticalAlignment="Center" Foreground="{StaticResource Foreground.Secondary}"
                               Margin="12,0" />

                    <!-- ログ書込 -->
                    <StackPanel Grid.Column="4" HorizontalAlignment="Center">
                        <Ellipse Width="44" Height="44" Fill="{Binding LogStatusBrush}">
                            <Ellipse.Effect>
                                <DropShadowEffect Color="Black" Opacity="0.35" BlurRadius="8" ShadowDepth="2" />
                            </Ellipse.Effect>
                        </Ellipse>
                        <TextBlock Text="ログ書込" FontSize="13" FontWeight="SemiBold"
                                   HorizontalAlignment="Center" Margin="0,8,0,2" />
                        <TextBlock Text="{Binding LogStatusText}"
                                   FontSize="11" HorizontalAlignment="Center"
                                   Foreground="{StaticResource Foreground.Secondary}" />
                    </StackPanel>
                </Grid>
            </Border>

            <!-- メトリクスカード -->
            <UniformGrid Grid.Row="1" Columns="4" Margin="0,14,0,0">
                <Border Background="{StaticResource Background.Panel}" CornerRadius="6" Padding="16" Margin="0,0,8,0"
                        Visibility="{Binding Display.ShowMessageCount, Converter={StaticResource BoolToVisibility}}">
                    <StackPanel>
                        <TextBlock Text="受信メッセージ数" Foreground="{StaticResource Foreground.Secondary}" FontSize="12" />
                        <TextBlock Text="{Binding TotalMessageCount, StringFormat={}{0:#,##0}}"
                                   FontSize="32" FontWeight="SemiBold" Margin="0,4,0,0" />
                    </StackPanel>
                </Border>
                <Border Background="{StaticResource Background.Panel}" CornerRadius="6" Padding="16" Margin="0,0,8,0"
                        Visibility="{Binding Display.ShowMessageRate, Converter={StaticResource BoolToVisibility}}">
                    <StackPanel>
                        <TextBlock Text="受信レート" Foreground="{StaticResource Foreground.Secondary}" FontSize="12" />
                        <TextBlock FontSize="32" FontWeight="SemiBold" Margin="0,4,0,0">
                            <Run Text="{Binding MessagesPerSecond, StringFormat={}{0:#0.0}}" />
                            <Run Text=" /s" FontSize="14" Foreground="{StaticResource Foreground.Secondary}" />
                        </TextBlock>
                    </StackPanel>
                </Border>
                <Border Background="{StaticResource Background.Panel}" CornerRadius="6" Padding="16" Margin="0,0,8,0"
                        Visibility="{Binding Display.ShowParseErrors, Converter={StaticResource BoolToVisibility}}">
                    <StackPanel>
                        <TextBlock Text="パースエラー" Foreground="{StaticResource Foreground.Secondary}" FontSize="12" />
                        <TextBlock Text="{Binding ParseErrorCount, StringFormat={}{0:#,##0}}"
                                   FontSize="32" FontWeight="SemiBold" Margin="0,4,0,0" />
                    </StackPanel>
                </Border>
                <Border Background="{StaticResource Background.Panel}" CornerRadius="6" Padding="16"
                        Visibility="{Binding Display.ShowLogSize, Converter={StaticResource BoolToVisibility}}">
                    <StackPanel>
                        <TextBlock Text="本日のログサイズ" Foreground="{StaticResource Foreground.Secondary}" FontSize="12" />
                        <TextBlock Text="{Binding LogSizeText}"
                                   FontSize="32" FontWeight="SemiBold" Margin="0,4,0,0" />
                    </StackPanel>
                </Border>
            </UniformGrid>

            <!-- 出力ファイルパス -->
            <Border Grid.Row="2" Background="{StaticResource Background.Panel}" CornerRadius="6" Padding="14"
                    Margin="0,14,0,0" VerticalAlignment="Top">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="保存先 (生)"
                               Foreground="{StaticResource Foreground.Secondary}" Margin="0,0,12,6" />
                    <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding CurrentRawLogPath}"
                               FontFamily="Consolas, Courier New" TextTrimming="CharacterEllipsis" Margin="0,0,0,6" />

                    <TextBlock Grid.Row="1" Grid.Column="0" Text="保存先 (解析済)"
                               Foreground="{StaticResource Foreground.Secondary}" Margin="0,0,12,6" />
                    <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding CurrentParsedLogPath}"
                               FontFamily="Consolas, Courier New" TextTrimming="CharacterEllipsis" Margin="0,0,0,6" />

                    <Button Grid.Row="0" Grid.Column="2" Grid.RowSpan="2"
                            Content="フォルダを開く"
                            Command="{Binding OpenLogsFolderCommand}"
                            Padding="14,6" VerticalAlignment="Center" Margin="12,0,0,0" />

                    <!-- デバッグ用最終受信メッセージ -->
                    <TextBlock Grid.Row="2" Grid.Column="0"
                               Text="最終メッセージ"
                               Foreground="{StaticResource Foreground.Secondary}" Margin="0,8,12,0"
                               Visibility="{Binding Display.ShowLastMessagePreview, Converter={StaticResource BoolToVisibility}}" />
                    <TextBlock Grid.Row="2" Grid.Column="1"
                               Text="{Binding LastMessageInfo}"
                               FontFamily="Consolas, Courier New" TextTrimming="CharacterEllipsis"
                               Margin="0,8,0,0"
                               Visibility="{Binding Display.ShowLastMessagePreview, Converter={StaticResource BoolToVisibility}}" />
                </Grid>
            </Border>
        </Grid>
    </DockPanel>
</Window>
