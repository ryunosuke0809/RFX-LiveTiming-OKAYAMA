<Window x:Class="RfxTiming.Smis.Receiver.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:RfxTiming.Smis.Receiver.ViewModels"
        Title="MOLA_Timing-Receiver"
        Width="1280" Height="800"
        MinWidth="900" MinHeight="600"
        FontFamily="Segoe UI, Yu Gothic UI, Meiryo UI"
        FontSize="13"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType">

    <Window.DataContext>
        <vm:MainViewModel />
    </Window.DataContext>

    <DockPanel LastChildFill="True">

        <!-- メニューバー -->
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="_File">
                <MenuItem Header="ログフォルダを開く (_O)" Command="{Binding OpenLogsFolderCommand}" />
                <Separator />
                <MenuItem Header="終了 (_X)" Command="{Binding ExitAppCommand}" />
            </MenuItem>
            <MenuItem Header="_Settings">
                <MenuItem Header="接続設定 (_C)..." Command="{Binding OpenConnectionSettingsCommand}" />
                <MenuItem Header="保存設定 (_L)..."
                          Command="{Binding ShowComingSoonCommand}"
                          CommandParameter="保存設定" />
                <MenuItem Header="配信設定 (_D)..."
                          Command="{Binding ShowComingSoonCommand}"
                          CommandParameter="配信設定" />
                <MenuItem Header="クラウド送信 (_U)..."
                          Command="{Binding ShowComingSoonCommand}"
                          CommandParameter="クラウド送信" />
            </MenuItem>
            <MenuItem Header="_View">
                <MenuItem Header="ダッシュボード (_D)" IsChecked="True" IsCheckable="True" />
            </MenuItem>
            <MenuItem Header="_Help">
                <MenuItem Header="SMIS プロトコル概要 (_S)"
                          Command="{Binding ShowComingSoonCommand}"
                          CommandParameter="SMIS プロトコル概要" />
                <Separator />
                <MenuItem Header="バージョン情報 (_A)..." Command="{Binding ShowAboutCommand}" />
            </MenuItem>
        </Menu>

        <!-- ツールバー -->
        <ToolBarTray DockPanel.Dock="Top" IsLocked="True">
            <ToolBar>
                <Button Content="接続" Command="{Binding ConnectCommand}" />
                <Button Content="切断" Command="{Binding DisconnectCommand}" />
                <Separator />
                <TextBlock Text="接続先:" VerticalAlignment="Center" Margin="8,0,6,0" />
                <TextBox Text="{Binding SmisHost, UpdateSourceTrigger=PropertyChanged}"
                         Width="120" VerticalAlignment="Center"
                         IsEnabled="{Binding IsRunning, Converter={x:Static vm:NotBoolConverter.Instance}}" />
                <TextBlock Text=":" VerticalAlignment="Center" Margin="2,0" />
                <TextBox Text="{Binding SmisPort, UpdateSourceTrigger=PropertyChanged}"
                         Width="60" VerticalAlignment="Center"
                         IsEnabled="{Binding IsRunning, Converter={x:Static vm:NotBoolConverter.Instance}}" />
                <Separator />
                <Button Content="ログフォルダを開く" Command="{Binding OpenLogsFolderCommand}" />
            </ToolBar>
        </ToolBarTray>

        <!-- ステータスバー -->
        <StatusBar DockPanel.Dock="Bottom">
            <StatusBarItem>
                <StackPanel Orientation="Horizontal">
                    <Ellipse Width="10" Height="10" Margin="0,0,6,0"
                             Fill="{Binding ConnectionStatusBrush}" />
                    <TextBlock Text="{Binding ConnectionStatusText}"
                               Foreground="{StaticResource Foreground.Secondary}" />
                </StackPanel>
            </StatusBarItem>
            <Separator />
            <StatusBarItem Content="{Binding CurrentOutputFile, StringFormat='出力: {0}'}" />
            <StatusBarItem HorizontalAlignment="Right">
                <TextBlock Text="{Binding TotalMessageCount, StringFormat='本日: {0} 件'}"
                           Foreground="{StaticResource Foreground.Secondary}" />
            </StatusBarItem>
        </StatusBar>

        <!-- メイン領域 -->
        <Grid Margin="16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0"
                       Text="MOLA_Timing-Receiver"
                       FontSize="24" FontWeight="SemiBold"
                       Margin="0,0,0,8" />

            <!-- メトリクス -->
            <UniformGrid Grid.Row="1" Columns="4" Margin="0,0,0,16">
                <Border Background="{StaticResource Background.Panel}" CornerRadius="6" Padding="16" Margin="0,0,8,0">
                    <StackPanel>
                        <TextBlock Text="受信メッセージ" Foreground="{StaticResource Foreground.Secondary}" FontSize="12" />
                        <TextBlock Text="{Binding TotalMessageCount}" FontSize="28" FontWeight="SemiBold" Margin="0,4,0,0" />
                    </StackPanel>
                </Border>
                <Border Background="{StaticResource Background.Panel}" CornerRadius="6" Padding="16" Margin="0,0,8,0">
                    <StackPanel>
                        <TextBlock Text="パースエラー" Foreground="{StaticResource Foreground.Secondary}" FontSize="12" />
                        <TextBlock Text="{Binding ParseErrorCount}" FontSize="28" FontWeight="SemiBold" Margin="0,4,0,0" />
                    </StackPanel>
                </Border>
                <Border Background="{StaticResource Background.Panel}" CornerRadius="6" Padding="16" Margin="0,0,8,0">
                    <StackPanel>
                        <TextBlock Text="状態" Foreground="{StaticResource Foreground.Secondary}" FontSize="12" />
                        <TextBlock Text="{Binding ConnectionStatusText}" FontSize="16" FontWeight="SemiBold" Margin="0,8,0,0"
                                   TextTrimming="CharacterEllipsis" />
                    </StackPanel>
                </Border>
                <Border Background="{StaticResource Background.Panel}" CornerRadius="6" Padding="16">
                    <StackPanel>
                        <TextBlock Text="最新メッセージ" Foreground="{StaticResource Foreground.Secondary}" FontSize="12" />
                        <TextBlock Text="{Binding LastMessageInfo}" FontSize="14" Margin="0,8,0,0"
                                   TextTrimming="CharacterEllipsis" />
                    </StackPanel>
                </Border>
            </UniformGrid>

            <Border Grid.Row="2"
                    Background="{StaticResource Background.Panel}"
                    CornerRadius="6"
                    Padding="20">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Text="使い方"
                                   FontSize="16" FontWeight="SemiBold" />
                        <TextBlock Foreground="{StaticResource Foreground.Secondary}"
                                   TextWrapping="Wrap"
                                   Margin="0,12,0,0"
                                   LineHeight="22">
                            <Run Text="1. MOLA_Timing-VirtualServer.exe を別ウィンドウで起動し、ポート 50000 で「▶ 再生」を押す" /><LineBreak />
                            <Run Text="2. このアプリで上のツールバーの「接続」を押す" /><LineBreak />
                            <Run Text="3. ステータスが「接続済」になり、メトリクスが増加していくのを確認" /><LineBreak />
                            <Run Text="4. ログは exe と同じフォルダーの logs/ 配下に保存されます (smis_raw_YYYYMMDD.txt と smis_parsed_YYYYMMDD.txt)" /><LineBreak />
                            <Run Text="5. 「ログフォルダを開く」ボタンで Explorer を開けます" />
                        </TextBlock>

                        <TextBlock Text="出力ファイル仕様"
                                   FontSize="14" FontWeight="SemiBold"
                                   Margin="0,20,0,0" />
                        <TextBlock Foreground="{StaticResource Foreground.Secondary}"
                                   TextWrapping="Wrap"
                                   Margin="0,8,0,0">
                            <Run Text="• smis_raw_*.txt : タブ区切り (受信時刻 / バイト長 / エスケープ済 XML)" /><LineBreak />
                            <Run Text="• smis_parsed_*.txt : JSON Lines （ts / type / payload を 1 行 1 メッセージ）" />
                        </TextBlock>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>
    </DockPanel>
</Window>
