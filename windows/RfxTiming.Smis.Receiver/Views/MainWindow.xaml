<Window x:Class="RfxTiming.Smis.Receiver.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:RfxTiming.Smis.Receiver.ViewModels"
        xmlns:conv="clr-namespace:RfxTiming.Smis.Receiver.ViewModels"
        Title="MOLA_Timing-Receiver"
        Width="1100" Height="680"
        MinWidth="860" MinHeight="540"
        FontFamily="Segoe UI, Yu Gothic UI, Meiryo UI"
        FontSize="13"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType">

    <Window.DataContext>
        <vm:MainViewModel />
    </Window.DataContext>

    <Window.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVisibility" />
        <conv:BoolToOnOffConverter x:Key="BoolToOnOff" />
    </Window.Resources>

    <DockPanel LastChildFill="True">

        <!-- メニューバー (常に表示するが最小限) -->
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="_File">
                <MenuItem Header="ログフォルダを開く (_L)" Command="{Binding OpenLogsFolderCommand}" />
                <Separator />
                <MenuItem Header="終了 (_X)" Command="{Binding ExitAppCommand}" />
            </MenuItem>
            <MenuItem Header="_Settings">
                <MenuItem Header="設定 (_O)..." Command="{Binding OpenSettingsCommand}" />
            </MenuItem>
            <MenuItem Header="_Help">
                <MenuItem Header="バージョン情報 (_A)..." Command="{Binding ShowAboutCommand}" />
            </MenuItem>
        </Menu>

        <!-- 主要アクションのツールバー -->
        <Border DockPanel.Dock="Top" Background="{StaticResource Background.Panel}" Padding="14,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0"
                        Content="▶ 接続開始"
                        Command="{Binding ConnectCommand}"
                        Padding="20,8" FontWeight="SemiBold" FontSize="14"
                        Margin="0,0,8,0" />
                <Button Grid.Column="1"
                        Content="■ 切断"
                        Command="{Binding DisconnectCommand}"
                        Padding="20,8" FontSize="14" />

                <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center">
                    <Ellipse Width="14" Height="14" Margin="0,0,8,0"
                             Fill="{Binding HeadlineStatusBrush}" />
                    <TextBlock Text="{Binding HeadlineStatusText}"
                               FontSize="14" FontWeight="SemiBold"
                               VerticalAlignment="Center"
                               Foreground="{StaticResource Foreground.Primary}" />
                </StackPanel>

                <Button Grid.Column="4"
                        Content="⚙ 設定"
                        Command="{Binding OpenSettingsCommand}"
                        Padding="14,8" Margin="16,0,0,0" />
            </Grid>
        </Border>

        <!-- ステータスバー -->
        <StatusBar DockPanel.Dock="Bottom">
            <StatusBarItem>
                <StackPanel Orientation="Horizontal">
                    <Ellipse Width="10" Height="10" Margin="0,0,6,0"
                             Fill="{Binding ReceiveStatusBrush}" />
                    <TextBlock Text="{Binding ConnectionEndpointText, StringFormat='接続先: {0}'}"
                               Foreground="{StaticResource Foreground.Secondary}" />
                </StackPanel>
            </StatusBarItem>
            <Separator />
            <StatusBarItem>
                <TextBlock Foreground="{StaticResource Foreground.Secondary}"
                           Visibility="{Binding Display.ShowLastReceivedAtInStatusBar, Converter={StaticResource BoolToVisibility}}">
                    <Run Text="最終受信: " />
                    <Run Text="{Binding LastReceivedAtText}" />
                </TextBlock>
            </StatusBarItem>
            <Separator />
            <StatusBarItem>
                <TextBlock Foreground="{StaticResource Foreground.Secondary}">
                    <Run Text="ログ: " />
                    <Run Text="{Binding LogSizeText}" />
                </TextBlock>
            </StatusBarItem>
            <StatusBarItem HorizontalAlignment="Right">
                <TextBlock Foreground="{StaticResource Foreground.Secondary}" FontSize="11"
                           Text="{Binding BuildInfoText}" />
            </StatusBarItem>
        </StatusBar>

        <!-- メイン領域: 接続ダッシュボード -->
        <Grid Margin="14">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!--
              ============================================
              Row 0: 接続情報パネル (Connection)
              ============================================
              現場運用で最も重要な「いま繋がっているか」を一目で確認するためのカード。
            -->
            <Border Grid.Row="0"
                    Background="{StaticResource Background.Panel}"
                    BorderBrush="{StaticResource Border.Subtle}" BorderThickness="1"
                    CornerRadius="6" Padding="20">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <!-- 左: 大きな状態ランプ + 状態テキスト -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,28,0">
                        <Ellipse Width="20" Height="20" Margin="0,0,12,0"
                                 Fill="{Binding HeadlineStatusBrush}" />
                        <StackPanel>
                            <TextBlock Text="{Binding HeadlineStatusText}"
                                       FontSize="20" FontWeight="SemiBold" />
                            <TextBlock Text="MOLA-Timing / SMIS 接続"
                                       FontSize="11"
                                       Foreground="{StaticResource Foreground.Secondary}"
                                       Margin="0,2,0,0" />
                        </StackPanel>
                    </StackPanel>

                    <!-- 右: 接続詳細 (2 列ラベル/値) -->
                    <Grid Grid.Column="1" VerticalAlignment="Center">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="110" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="120" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="接続先"
                                   Foreground="{StaticResource Foreground.Secondary}" Margin="0,0,0,6" />
                        <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding ConnectionEndpointText}"
                                   FontFamily="Consolas, Courier New" Margin="0,0,16,6" />

                        <TextBlock Grid.Row="0" Grid.Column="2" Text="自動再接続"
                                   Foreground="{StaticResource Foreground.Secondary}" Margin="0,0,0,6" />
                        <TextBlock Grid.Row="0" Grid.Column="3" Margin="0,0,0,6">
                            <Run Text="{Binding AutoReconnect, Converter={StaticResource BoolToOnOff}}" />
                        </TextBlock>

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="最終受信"
                                   Foreground="{StaticResource Foreground.Secondary}" />
                        <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding LastReceivedAtText}"
                                   FontFamily="Consolas, Courier New" Margin="0,0,16,0" />

                        <TextBlock Grid.Row="1" Grid.Column="2" Text="ログサイズ"
                                   Foreground="{StaticResource Foreground.Secondary}" />
                        <TextBlock Grid.Row="1" Grid.Column="3" Text="{Binding LogSizeText}" />
                    </Grid>
                </Grid>
            </Border>

            <!--
              ============================================
              Row 1: シンプルなカウンタ 3 つ (Throughput / Errors)
              ============================================
            -->
            <Grid Grid.Row="1" Margin="0,14,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Background="{StaticResource Background.Panel}"
                        BorderBrush="{StaticResource Border.Subtle}" BorderThickness="1"
                        CornerRadius="6" Padding="16" Margin="0,0,7,0"
                        Visibility="{Binding Display.ShowMessageCount, Converter={StaticResource BoolToVisibility}}">
                    <StackPanel>
                        <TextBlock Text="受信メッセージ数" Foreground="{StaticResource Foreground.Secondary}" FontSize="12" />
                        <TextBlock Text="{Binding TotalMessageCount, StringFormat={}{0:#,##0}}"
                                   FontSize="28" FontWeight="SemiBold" Margin="0,4,0,0" />
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" Background="{StaticResource Background.Panel}"
                        BorderBrush="{StaticResource Border.Subtle}" BorderThickness="1"
                        CornerRadius="6" Padding="16" Margin="7,0,7,0"
                        Visibility="{Binding Display.ShowMessageRate, Converter={StaticResource BoolToVisibility}}">
                    <StackPanel>
                        <TextBlock Text="受信レート" Foreground="{StaticResource Foreground.Secondary}" FontSize="12" />
                        <TextBlock FontSize="28" FontWeight="SemiBold" Margin="0,4,0,0">
                            <Run Text="{Binding MessagesPerSecond, StringFormat={}{0:#0.0}}" />
                            <Run Text=" msg/s" FontSize="13" Foreground="{StaticResource Foreground.Secondary}" />
                        </TextBlock>
                    </StackPanel>
                </Border>

                <Border Grid.Column="2" Background="{StaticResource Background.Panel}"
                        BorderBrush="{StaticResource Border.Subtle}" BorderThickness="1"
                        CornerRadius="6" Padding="16" Margin="7,0,0,0"
                        Visibility="{Binding Display.ShowParseErrors, Converter={StaticResource BoolToVisibility}}">
                    <StackPanel>
                        <TextBlock Text="エラー件数" Foreground="{StaticResource Foreground.Secondary}" FontSize="12" />
                        <Grid Margin="0,4,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="{Binding ParseErrorCount, StringFormat={}{0:#,##0}}"
                                           FontSize="22" FontWeight="SemiBold" />
                                <TextBlock Text="パース失敗" FontSize="11"
                                           Foreground="{StaticResource Foreground.Secondary}" />
                            </StackPanel>
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="{Binding LogWriteErrorCount, StringFormat={}{0:#,##0}}"
                                           FontSize="22" FontWeight="SemiBold" />
                                <TextBlock Text="書込失敗" FontSize="11"
                                           Foreground="{StaticResource Foreground.Secondary}" />
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>
            </Grid>

            <!--
              ============================================
              Row 2: ログ出力先
              ============================================
            -->
            <Border Grid.Row="2" Background="{StaticResource Background.Panel}"
                    BorderBrush="{StaticResource Border.Subtle}" BorderThickness="1"
                    CornerRadius="6" Padding="16" Margin="0,14,0,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="110" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="ログ出力先"
                               FontWeight="SemiBold" Margin="0,0,0,8" />
                    <StackPanel Grid.Row="0" Grid.Column="2" Orientation="Horizontal" Margin="0,0,0,8">
                        <Border Background="{StaticResource Background.Hover}"
                                CornerRadius="10" Padding="10,3" Margin="0,0,8,0"
                                ToolTip="日付が変わって新しい日付のログファイルに自動切替された回数">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="↻ ロール: "
                                           Foreground="{StaticResource Foreground.Secondary}" FontSize="11" />
                                <TextBlock Text="{Binding LogRotationCount}"
                                           Foreground="{StaticResource Foreground.Primary}" FontSize="11" FontWeight="SemiBold" />
                            </StackPanel>
                        </Border>
                        <Button Content="フォルダを開く"
                                Command="{Binding OpenLogsFolderCommand}"
                                Padding="14,4" />
                    </StackPanel>

                    <TextBlock Grid.Row="1" Grid.Column="0" Text="生 XML"
                               Foreground="{StaticResource Foreground.Secondary}" Margin="0,0,12,4" />
                    <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding CurrentRawLogPath}"
                               FontFamily="Consolas, Courier New" TextTrimming="CharacterEllipsis" Margin="0,0,12,4" />

                    <TextBlock Grid.Row="2" Grid.Column="0" Text="解析済 (JSONL)"
                               Foreground="{StaticResource Foreground.Secondary}" Margin="0,0,12,0" />
                    <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding CurrentParsedLogPath}"
                               FontFamily="Consolas, Courier New" TextTrimming="CharacterEllipsis" Margin="0,0,12,0" />
                </Grid>
            </Border>

            <!--
              ============================================
              Row 3: クラウド配信カード (Phase 2)
              ============================================
            -->
            <Border Grid.Row="3" Background="{StaticResource Background.Panel}"
                    BorderBrush="{StaticResource Border.Subtle}" BorderThickness="1"
                    CornerRadius="6" Padding="16" Margin="0,14,0,0"
                    VerticalAlignment="Top">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Grid.Column="0" Orientation="Horizontal" Margin="0,0,16,8">
                        <Ellipse Width="12" Height="12" VerticalAlignment="Center"
                                 Fill="{Binding CloudStatusBrush}" Margin="0,0,8,0" />
                        <TextBlock Text="クラウド配信" FontWeight="SemiBold" />
                    </StackPanel>
                    <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding CloudStatusText}"
                               FontSize="13" VerticalAlignment="Center" Margin="0,0,0,8" />
                    <TextBlock Grid.Row="0" Grid.Column="2" Text="{Binding CloudEndpointText}"
                               FontFamily="Consolas, Courier New" FontSize="12"
                               Foreground="{StaticResource Foreground.Secondary}"
                               TextTrimming="CharacterEllipsis"
                               VerticalAlignment="Center" Margin="0,0,0,8"
                               MaxWidth="420" />

                    <UniformGrid Grid.Row="1" Grid.ColumnSpan="3" Columns="3">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="送信: " Foreground="{StaticResource Foreground.Secondary}" />
                            <TextBlock Text="{Binding CloudSentCount, StringFormat={}{0:#,##0}}" FontWeight="SemiBold" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="キュー: " Foreground="{StaticResource Foreground.Secondary}" />
                            <TextBlock Text="{Binding CloudQueueDepth, StringFormat={}{0:#,##0}}" FontWeight="SemiBold" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="失敗: " Foreground="{StaticResource Foreground.Secondary}" />
                            <TextBlock Text="{Binding CloudFailedCount, StringFormat={}{0:#,##0}}" FontWeight="SemiBold" />
                        </StackPanel>
                    </UniformGrid>
                </Grid>
            </Border>

            <!--
              ============================================
              Row 4: 最終受信メッセージ (デバッグ表示)
              ============================================
            -->
            <Border Grid.Row="4" Background="{StaticResource Background.Panel}"
                    BorderBrush="{StaticResource Border.Subtle}" BorderThickness="1"
                    CornerRadius="6" Padding="14" Margin="0,14,0,0" VerticalAlignment="Top"
                    Visibility="{Binding Display.ShowLastMessagePreview, Converter={StaticResource BoolToVisibility}}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="110" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="最終メッセージ"
                               Foreground="{StaticResource Foreground.Secondary}" Margin="0,0,12,0" />
                    <TextBlock Grid.Column="1" Text="{Binding LastMessageInfo}"
                               FontFamily="Consolas, Courier New" TextTrimming="CharacterEllipsis" />
                </Grid>
            </Border>
        </Grid>
    </DockPanel>
</Window>
