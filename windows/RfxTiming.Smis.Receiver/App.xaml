<Application x:Class="RfxTiming.Smis.Receiver.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             StartupUri="Views/MainWindow.xaml">
    <Application.Resources>
        <ResourceDictionary>

            <!-- カラーパレット -->
            <SolidColorBrush x:Key="Background.Window" Color="#0F1419" />
            <SolidColorBrush x:Key="Background.Panel" Color="#1A1F2E" />
            <SolidColorBrush x:Key="Background.Hover" Color="#2A3142" />
            <SolidColorBrush x:Key="Background.Selected" Color="#1F6FEB" />
            <SolidColorBrush x:Key="Foreground.Primary" Color="#E6EDF3" />
            <SolidColorBrush x:Key="Foreground.Secondary" Color="#9BA1A6" />
            <SolidColorBrush x:Key="Border.Subtle" Color="#30363D" />
            <SolidColorBrush x:Key="Accent.Connected" Color="#3FB950" />
            <SolidColorBrush x:Key="Accent.Disconnected" Color="#F85149" />
            <SolidColorBrush x:Key="Accent.Reconnecting" Color="#D29922" />

            <!--
              ===== SystemColors override =====
              Menu のドロップダウン Popup は SystemColors.* を直接参照する。
              Popup 本体は Windows 標準のライト (白) のままにして文字を黒で読みやすくするため、
              MenuBrush 等は意図的に上書きしない。
              ControlBrush / WindowBrush 等の dark ボタン/ダイアログ向けキーだけ上書きする。
            -->
            <SolidColorBrush x:Key="{x:Static SystemColors.ControlBrushKey}" Color="#1A1F2E" />
            <SolidColorBrush x:Key="{x:Static SystemColors.ControlTextBrushKey}" Color="#E6EDF3" />
            <SolidColorBrush x:Key="{x:Static SystemColors.GrayTextBrushKey}" Color="#6B7280" />
            <SolidColorBrush x:Key="{x:Static SystemColors.WindowBrushKey}" Color="#0F1419" />
            <SolidColorBrush x:Key="{x:Static SystemColors.WindowTextBrushKey}" Color="#E6EDF3" />

            <!-- ===== Menu / MenuItem ダークテーマ ===== -->
            <Style TargetType="{x:Type Menu}">
                <Setter Property="Background" Value="{StaticResource Background.Panel}" />
                <Setter Property="Foreground" Value="{StaticResource Foreground.Primary}" />
            </Style>

            <!--
              MenuItem の Role 別スタイル:
              - TopLevelHeader/Item (上端): ダーク地に白文字
              - SubmenuHeader/Item (ドロップダウン): 白地に黒文字 (Windows 標準)
            -->
            <Style TargetType="{x:Type MenuItem}">
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="Padding" Value="8,4" />
                <Style.Triggers>
                    <Trigger Property="Role" Value="TopLevelHeader">
                        <Setter Property="Foreground" Value="{StaticResource Foreground.Primary}" />
                    </Trigger>
                    <Trigger Property="Role" Value="TopLevelItem">
                        <Setter Property="Foreground" Value="{StaticResource Foreground.Primary}" />
                    </Trigger>
                    <Trigger Property="Role" Value="SubmenuHeader">
                        <Setter Property="Foreground" Value="Black" />
                    </Trigger>
                    <Trigger Property="Role" Value="SubmenuItem">
                        <Setter Property="Foreground" Value="Black" />
                    </Trigger>
                </Style.Triggers>
            </Style>

            <!-- ContextMenu 本体は Windows 標準ライトのまま、文字は黒に -->
            <Style TargetType="{x:Type ContextMenu}">
                <Setter Property="Foreground" Value="Black" />
            </Style>

            <!-- セパレータ -->
            <Style TargetType="{x:Type Separator}">
                <Setter Property="Background" Value="{StaticResource Border.Subtle}" />
                <Setter Property="Height" Value="1" />
            </Style>

            <!-- ===== ToolBar ===== -->
            <Style TargetType="{x:Type ToolBarTray}">
                <Setter Property="Background" Value="{StaticResource Background.Panel}" />
            </Style>

            <Style TargetType="{x:Type ToolBar}">
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="Foreground" Value="{StaticResource Foreground.Primary}" />
            </Style>

            <!-- ===== Button (ToolBar 内の既定ボタンを含む) ===== -->
            <Style TargetType="{x:Type Button}">
                <Setter Property="Background" Value="{StaticResource Background.Hover}" />
                <Setter Property="Foreground" Value="{StaticResource Foreground.Primary}" />
                <Setter Property="BorderBrush" Value="{StaticResource Border.Subtle}" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="Padding" Value="12,4" />
                <Setter Property="Cursor" Value="Hand" />
                <Setter Property="FocusVisualStyle" Value="{x:Null}" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="{x:Type Button}">
                            <Border Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="4"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="{StaticResource Background.Selected}" />
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter Property="Background" Value="{StaticResource Background.Selected}" />
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter Property="Opacity" Value="0.5" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- ToggleButton (VirtualServer の Loop ボタンと同じ系統に) -->
            <Style TargetType="{x:Type ToggleButton}">
                <Setter Property="Background" Value="{StaticResource Background.Hover}" />
                <Setter Property="Foreground" Value="{StaticResource Foreground.Primary}" />
                <Setter Property="BorderBrush" Value="{StaticResource Border.Subtle}" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="Padding" Value="12,4" />
                <Setter Property="Cursor" Value="Hand" />
            </Style>

            <!-- ComboBox -->
            <Style TargetType="{x:Type ComboBox}">
                <Setter Property="Background" Value="{StaticResource Background.Hover}" />
                <Setter Property="Foreground" Value="{StaticResource Foreground.Primary}" />
                <Setter Property="BorderBrush" Value="{StaticResource Border.Subtle}" />
            </Style>

            <!-- TextBox -->
            <Style TargetType="{x:Type TextBox}">
                <Setter Property="Background" Value="{StaticResource Background.Hover}" />
                <Setter Property="Foreground" Value="{StaticResource Foreground.Primary}" />
                <Setter Property="BorderBrush" Value="{StaticResource Border.Subtle}" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="Padding" Value="6,2" />
                <Setter Property="CaretBrush" Value="{StaticResource Foreground.Primary}" />
                <Setter Property="SelectionBrush" Value="{StaticResource Background.Selected}" />
            </Style>

            <!-- CheckBox -->
            <Style TargetType="{x:Type CheckBox}">
                <Setter Property="Foreground" Value="{StaticResource Foreground.Primary}" />
                <Setter Property="Background" Value="{StaticResource Background.Hover}" />
                <Setter Property="BorderBrush" Value="{StaticResource Border.Subtle}" />
            </Style>

            <!-- ===== StatusBar ===== -->
            <Style TargetType="{x:Type StatusBar}">
                <Setter Property="Background" Value="{StaticResource Background.Panel}" />
                <Setter Property="Foreground" Value="{StaticResource Foreground.Secondary}" />
            </Style>

            <Style TargetType="{x:Type StatusBarItem}">
                <Setter Property="Foreground" Value="{StaticResource Foreground.Secondary}" />
                <Setter Property="Padding" Value="6,2" />
            </Style>

            <!-- TextBlock (規定の文字色をダーク向けに) -->
            <Style TargetType="{x:Type TextBlock}">
                <Setter Property="Foreground" Value="{StaticResource Foreground.Primary}" />
            </Style>

            <!-- Window (規定の文字色) -->
            <Style TargetType="{x:Type Window}">
                <Setter Property="Background" Value="{StaticResource Background.Window}" />
                <Setter Property="Foreground" Value="{StaticResource Foreground.Primary}" />
            </Style>

        </ResourceDictionary>
    </Application.Resources>
</Application>
