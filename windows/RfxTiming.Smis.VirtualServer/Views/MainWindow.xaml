<Window x:Class="RfxTiming.Smis.VirtualServer.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:RfxTiming.Smis.VirtualServer.ViewModels"
        Title="MOLA_Timing-VirtualServer"
        Width="1280" Height="820"
        MinWidth="900" MinHeight="640"
        FontFamily="Segoe UI, Yu Gothic UI, Meiryo UI"
        FontSize="13"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType">

    <Window.DataContext>
        <vm:MainViewModel />
    </Window.DataContext>

    <DockPanel LastChildFill="True">

        <!-- メニューバー -->
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="_File">
                <MenuItem Header="ログファイルを開く (_O)..."
                          Command="{Binding OpenLogFileCommand}" />
                <MenuItem Header="組み込みサンプルに戻す (_C)"
                          Command="{Binding ClearLoadedLogCommand}" />
                <Separator />
                <MenuItem Header="終了 (_X)" Command="{Binding ExitAppCommand}" />
            </MenuItem>
            <MenuItem Header="_Playback">
                <MenuItem Header="サーバー起動 (_R)" Command="{Binding StartServerCommand}" />
                <MenuItem Header="サーバー停止 (_T)" Command="{Binding StopServerCommand}" />
                <Separator />
                <MenuItem Header="再生 (_P)" Command="{Binding PlayCommand}" />
                <MenuItem Header="停止 (_S)" Command="{Binding StopPlaybackCommand}" />
            </MenuItem>
            <MenuItem Header="_Help">
                <MenuItem Header="使い方 (_H)"
                          Command="{Binding ShowComingSoonCommand}"
                          CommandParameter="使い方ガイド" />
                <Separator />
                <MenuItem Header="バージョン情報 (_A)..." Command="{Binding ShowAboutCommand}" />
            </MenuItem>
        </Menu>

        <!-- ツールバー -->
        <ToolBarTray DockPanel.Dock="Top" IsLocked="True">
            <ToolBar>
                <Button Content="サーバー起動" Command="{Binding StartServerCommand}" />
                <Button Content="サーバー停止" Command="{Binding StopServerCommand}" />
                <Separator />
                <TextBlock Text="ポート:" VerticalAlignment="Center" Margin="8,0,6,0" />
                <TextBox Text="{Binding ListenPort, UpdateSourceTrigger=PropertyChanged}"
                         Width="70" VerticalAlignment="Center" />
                <Separator />
                <Button Content="ログを開く..." Command="{Binding OpenLogFileCommand}" />
                <Button Content="サンプルに戻す" Command="{Binding ClearLoadedLogCommand}" />
                <Separator />
                <Button Content="▶ 再生" Command="{Binding PlayCommand}" />
                <Button Content="⏹ 停止" Command="{Binding StopPlaybackCommand}" />
                <Separator />
                <TextBlock Text="速度:" VerticalAlignment="Center" Margin="8,0,6,0" />
                <ComboBox ItemsSource="{Binding SpeedOptions}"
                          DisplayMemberPath="Label"
                          SelectedItem="{Binding SelectedSpeedOption}"
                          Width="130" VerticalAlignment="Center" />
                <Separator />
                <CheckBox Content="ループ再生"
                          IsChecked="{Binding LoopPlayback}"
                          VerticalAlignment="Center"
                          Foreground="{StaticResource Foreground.Primary}" />
            </ToolBar>
        </ToolBarTray>

        <!-- ステータスバー -->
        <StatusBar DockPanel.Dock="Bottom">
            <StatusBarItem>
                <StackPanel Orientation="Horizontal">
                    <Ellipse Width="10" Height="10" Margin="0,0,6,0"
                             Fill="{Binding PlaybackStatusBrush}" />
                    <TextBlock Text="{Binding PlaybackStatusText}"
                               Foreground="{StaticResource Foreground.Secondary}" />
                </StackPanel>
            </StatusBarItem>
            <Separator />
            <StatusBarItem Content="{Binding LoadedLogFile, StringFormat='ソース: {0}'}" />
            <StatusBarItem HorizontalAlignment="Right">
                <TextBlock Text="{Binding ConnectedClientCount, StringFormat='接続クライアント: {0}'}"
                           Foreground="{StaticResource Foreground.Secondary}" />
            </StatusBarItem>
        </StatusBar>

        <!-- メイン領域 -->
        <Grid Margin="16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0"
                       Text="MOLA_Timing-VirtualServer"
                       FontSize="24" FontWeight="SemiBold"
                       Margin="0,0,0,8" />

            <!-- メトリクス -->
            <UniformGrid Grid.Row="1" Columns="4" Margin="0,0,0,12">
                <Border Background="{StaticResource Background.Panel}" CornerRadius="6" Padding="16" Margin="0,0,8,0">
                    <StackPanel>
                        <TextBlock Text="送信済フレーム" Foreground="{StaticResource Foreground.Secondary}" FontSize="12" />
                        <TextBlock Text="{Binding TotalSent}" FontSize="28" FontWeight="SemiBold" Margin="0,4,0,0" />
                    </StackPanel>
                </Border>
                <Border Background="{StaticResource Background.Panel}" CornerRadius="6" Padding="16" Margin="0,0,8,0">
                    <StackPanel>
                        <TextBlock Text="接続クライアント数" Foreground="{StaticResource Foreground.Secondary}" FontSize="12" />
                        <TextBlock Text="{Binding ConnectedClientCount}" FontSize="28" FontWeight="SemiBold" Margin="0,4,0,0" />
                    </StackPanel>
                </Border>
                <Border Background="{StaticResource Background.Panel}" CornerRadius="6" Padding="16" Margin="0,0,8,0">
                    <StackPanel>
                        <TextBlock Text="状態" Foreground="{StaticResource Foreground.Secondary}" FontSize="12" />
                        <TextBlock Text="{Binding PlaybackStatusText}" FontSize="16" FontWeight="SemiBold" Margin="0,8,0,0"
                                   TextTrimming="CharacterEllipsis" />
                    </StackPanel>
                </Border>
                <Border Background="{StaticResource Background.Panel}" CornerRadius="6" Padding="16">
                    <StackPanel>
                        <TextBlock Text="ロード済エントリ" Foreground="{StaticResource Foreground.Secondary}" FontSize="12" />
                        <TextBlock Text="{Binding LoadedEntryCount, StringFormat={}{0:#,##0}}"
                                   FontSize="28" FontWeight="SemiBold" Margin="0,4,0,0" />
                    </StackPanel>
                </Border>
            </UniformGrid>

            <!-- 進捗バー -->
            <Border Grid.Row="2"
                    Background="{StaticResource Background.Panel}"
                    CornerRadius="6"
                    Padding="16,12"
                    Margin="0,0,0,12">
                <StackPanel>
                    <Grid Margin="0,0,0,6">
                        <TextBlock Text="再生進捗"
                                   Foreground="{StaticResource Foreground.Secondary}" FontSize="12" />
                        <TextBlock HorizontalAlignment="Right"
                                   Foreground="{StaticResource Foreground.Secondary}" FontSize="12">
                            <Run Text="{Binding CurrentReplayIndex, StringFormat={}{0:#,##0}}" />
                            <Run Text=" / " />
                            <Run Text="{Binding ReplayTotalCount, StringFormat={}{0:#,##0}}" />
                        </TextBlock>
                    </Grid>
                    <ProgressBar Height="10"
                                 Maximum="{Binding ReplayTotalCount}"
                                 Value="{Binding CurrentReplayIndex}"
                                 Foreground="{StaticResource Background.Selected}"
                                 Background="{StaticResource Background.Hover}"
                                 BorderBrush="{StaticResource Border.Subtle}" />
                </StackPanel>
            </Border>

            <!-- 使い方 / 最終フレーム -->
            <Border Grid.Row="3"
                    Background="{StaticResource Background.Panel}"
                    CornerRadius="6"
                    Padding="20">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Text="使い方"
                                   FontSize="16" FontWeight="SemiBold" />
                        <TextBlock Foreground="{StaticResource Foreground.Secondary}"
                                   TextWrapping="Wrap"
                                   Margin="0,12,0,0"
                                   LineHeight="22">
                            <Run Text="1. ツールバーの「ログを開く...」で SEIKO 互換ログ (seiko_YYYYMMDD.log) を選択。未選択なら組み込みサンプルを使用。" /><LineBreak />
                            <Run Text="2. 「サーバー起動」 → ポート (既定 50000) で待受開始。" /><LineBreak />
                            <Run Text="3. MOLA_Timing-Receiver から 127.0.0.1:50000 に接続。" /><LineBreak />
                            <Run Text="4. 速度プリセットを選んで「▶ 再生」。ループ再生もチェックで切替。" /><LineBreak />
                            <Run Text="5. SEIKO ログの場合、行のタイムスタンプ差分どおりにディレイをかけて配信。" />
                        </TextBlock>

                        <TextBlock Text="ログフォーマット"
                                   FontSize="14" FontWeight="SemiBold"
                                   Margin="0,20,0,0" />
                        <TextBlock Foreground="{StaticResource Foreground.Secondary}"
                                   TextWrapping="Wrap"
                                   Margin="0,8,0,0"
                                   FontFamily="Consolas, Courier New">
                            <Run Text="2026-03-27 13:32:36.204 &lt;Competition ID=&quot;477&quot; .../&gt;" /><LineBreak />
                            <Run Text="2026-03-27 13:32:36.246 &lt;Category ID=&quot;477:1&quot; .../&gt;" />
                        </TextBlock>
                        <TextBlock Foreground="{StaticResource Foreground.Secondary}"
                                   TextWrapping="Wrap"
                                   Margin="0,4,0,0"
                                   FontSize="11">
                            タイムスタンプ (yyyy-MM-dd HH:mm:ss.fff) + 半角スペース + 1 行 XML + 改行。
                            別プロジェクト (SEIKO 計時系) と互換のため、過去ログをそのままここで再生できます。
                        </TextBlock>

                        <TextBlock Text="最終送信フレーム" FontSize="14" FontWeight="SemiBold" Margin="0,20,0,0" />
                        <TextBlock Text="{Binding LastSentInfo}"
                                   Foreground="{StaticResource Foreground.Secondary}"
                                   TextWrapping="Wrap"
                                   Margin="0,8,0,0"
                                   FontFamily="Consolas, Courier New" />
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>
    </DockPanel>
</Window>
