<Application x:Class="RfxTiming.Smis.VirtualServer.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             StartupUri="Views/MainWindow.xaml">
    <Application.Resources>
        <ResourceDictionary>

            <!-- カラーパレット -->
            <SolidColorBrush x:Key="Background.Window" Color="#0F1419" />
            <SolidColorBrush x:Key="Background.Panel" Color="#1A1F2E" />
            <SolidColorBrush x:Key="Background.Hover" Color="#2A3142" />
            <SolidColorBrush x:Key="Background.Selected" Color="#1F6FEB" />
            <SolidColorBrush x:Key="Foreground.Primary" Color="#E6EDF3" />
            <SolidColorBrush x:Key="Foreground.Secondary" Color="#9BA1A6" />
            <SolidColorBrush x:Key="Border.Subtle" Color="#30363D" />
            <SolidColorBrush x:Key="Accent.Playing" Color="#3FB950" />
            <SolidColorBrush x:Key="Accent.Stopped" Color="#9BA1A6" />
            <SolidColorBrush x:Key="Accent.Paused" Color="#D29922" />

            <!-- SystemColors override (詳細は Receiver/App.xaml のコメント参照) -->
            <SolidColorBrush x:Key="{x:Static SystemColors.ControlBrushKey}" Color="#1A1F2E" />
            <SolidColorBrush x:Key="{x:Static SystemColors.ControlTextBrushKey}" Color="#E6EDF3" />
            <SolidColorBrush x:Key="{x:Static SystemColors.GrayTextBrushKey}" Color="#6B7280" />
            <SolidColorBrush x:Key="{x:Static SystemColors.WindowBrushKey}" Color="#0F1419" />
            <SolidColorBrush x:Key="{x:Static SystemColors.WindowTextBrushKey}" Color="#E6EDF3" />

            <!-- ===== Menu / MenuItem ===== -->
            <Style TargetType="{x:Type Menu}">
                <Setter Property="Background" Value="{StaticResource Background.Panel}" />
                <Setter Property="Foreground" Value="{StaticResource Foreground.Primary}" />
            </Style>

            <Style TargetType="{x:Type MenuItem}">
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="Padding" Value="8,4" />
                <Style.Triggers>
                    <Trigger Property="Role" Value="TopLevelHeader">
                        <Setter Property="Foreground" Value="{StaticResource Foreground.Primary}" />
                    </Trigger>
                    <Trigger Property="Role" Value="TopLevelItem">
                        <Setter Property="Foreground" Value="{StaticResource Foreground.Primary}" />
                    </Trigger>
                    <Trigger Property="Role" Value="SubmenuHeader">
                        <Setter Property="Foreground" Value="Black" />
                    </Trigger>
                    <Trigger Property="Role" Value="SubmenuItem">
                        <Setter Property="Foreground" Value="Black" />
                    </Trigger>
                </Style.Triggers>
            </Style>

            <Style TargetType="{x:Type ContextMenu}">
                <Setter Property="Foreground" Value="Black" />
            </Style>

            <Style TargetType="{x:Type Separator}">
                <Setter Property="Background" Value="{StaticResource Border.Subtle}" />
                <Setter Property="Height" Value="1" />
            </Style>

            <!-- ===== ToolBar ===== -->
            <Style TargetType="{x:Type ToolBarTray}">
                <Setter Property="Background" Value="{StaticResource Background.Panel}" />
            </Style>

            <Style TargetType="{x:Type ToolBar}">
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="Foreground" Value="{StaticResource Foreground.Primary}" />
            </Style>

            <!-- ===== Button ===== -->
            <Style TargetType="{x:Type Button}">
                <Setter Property="Background" Value="{StaticResource Background.Hover}" />
                <Setter Property="Foreground" Value="{StaticResource Foreground.Primary}" />
                <Setter Property="BorderBrush" Value="{StaticResource Border.Subtle}" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="Padding" Value="12,4" />
                <Setter Property="Cursor" Value="Hand" />
                <Setter Property="FocusVisualStyle" Value="{x:Null}" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="{x:Type Button}">
                            <Border Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="4"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="{StaticResource Background.Selected}" />
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter Property="Background" Value="{StaticResource Background.Selected}" />
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter Property="Opacity" Value="0.5" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style TargetType="{x:Type ToggleButton}">
                <Setter Property="Background" Value="{StaticResource Background.Hover}" />
                <Setter Property="Foreground" Value="{StaticResource Foreground.Primary}" />
                <Setter Property="BorderBrush" Value="{StaticResource Border.Subtle}" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="Padding" Value="12,4" />
                <Setter Property="Cursor" Value="Hand" />
            </Style>

            <Style TargetType="{x:Type ComboBox}">
                <Setter Property="Background" Value="{StaticResource Background.Hover}" />
                <Setter Property="Foreground" Value="{StaticResource Foreground.Primary}" />
                <Setter Property="BorderBrush" Value="{StaticResource Border.Subtle}" />
            </Style>

            <!-- TextBox -->
            <Style TargetType="{x:Type TextBox}">
                <Setter Property="Background" Value="{StaticResource Background.Hover}" />
                <Setter Property="Foreground" Value="{StaticResource Foreground.Primary}" />
                <Setter Property="BorderBrush" Value="{StaticResource Border.Subtle}" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="Padding" Value="6,2" />
                <Setter Property="CaretBrush" Value="{StaticResource Foreground.Primary}" />
                <Setter Property="SelectionBrush" Value="{StaticResource Background.Selected}" />
            </Style>

            <!-- CheckBox -->
            <Style TargetType="{x:Type CheckBox}">
                <Setter Property="Foreground" Value="{StaticResource Foreground.Primary}" />
                <Setter Property="Background" Value="{StaticResource Background.Hover}" />
                <Setter Property="BorderBrush" Value="{StaticResource Border.Subtle}" />
            </Style>

            <!-- ProgressBar -->
            <Style TargetType="{x:Type ProgressBar}">
                <Setter Property="Background" Value="{StaticResource Background.Hover}" />
                <Setter Property="Foreground" Value="{StaticResource Background.Selected}" />
                <Setter Property="BorderBrush" Value="{StaticResource Border.Subtle}" />
            </Style>

            <!-- ===== StatusBar ===== -->
            <Style TargetType="{x:Type StatusBar}">
                <Setter Property="Background" Value="{StaticResource Background.Panel}" />
                <Setter Property="Foreground" Value="{StaticResource Foreground.Secondary}" />
            </Style>

            <Style TargetType="{x:Type StatusBarItem}">
                <Setter Property="Foreground" Value="{StaticResource Foreground.Secondary}" />
                <Setter Property="Padding" Value="6,2" />
            </Style>

            <Style TargetType="{x:Type TextBlock}">
                <Setter Property="Foreground" Value="{StaticResource Foreground.Primary}" />
            </Style>

            <Style TargetType="{x:Type Window}">
                <Setter Property="Background" Value="{StaticResource Background.Window}" />
                <Setter Property="Foreground" Value="{StaticResource Foreground.Primary}" />
            </Style>

            <!-- Slider (タイムライン用) -->
            <Style TargetType="{x:Type Slider}">
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="Foreground" Value="{StaticResource Accent.Playing}" />
            </Style>

        </ResourceDictionary>
    </Application.Resources>
</Application>
