# ============================================================
# MOLA_Timing クラウドサーバー設定
# ============================================================
# このファイルを `.env` にコピーしてから値を埋めてください。
# 本番環境では絶対に .env をリポジトリにコミットしないこと。

# ---- HTTP / WebSocket ----
# 待受ポート (nginx の裏側で動かす場合は 127.0.0.1 で十分)
PORT=4000

# バインドアドレス
#   - 開発: 127.0.0.1 (ローカルのみ)
#   - VPS で nginx の後ろ:    127.0.0.1
#   - VPS で直接公開:        0.0.0.0
HOST=127.0.0.1

# ---- 認証 ----
# Receiver が /ingest 接続時に送る Bearer トークン。
# 本番では openssl rand -hex 32 などで十分長いランダム値を生成して使うこと。
RECEIVER_INGEST_TOKEN=change-me-to-a-long-random-secret

# フロントエンド (/ws) 接続時に求める短期トークン (任意)。
# 空文字なら認証なしで誰でも閲覧可能 (Phase 1 / 2 開発用)。
FRONTEND_VIEW_TOKEN=

# 許可する Origin (カンマ区切り)。空なら検証しない。
#   例: https://livetiming.example.com,http://localhost:3000
ALLOWED_ORIGINS=

# ---- データベース ----
# SQLite ファイルの置き場所。日付別 (timing_YYYYMMDD.db) は自動付与。
DATA_DIR=./data

# 1 セッションあたりにメモリ上に保持する最新メッセージ数 (frontend の "初回接続時に再送" 用)
RECENT_MESSAGE_BUFFER=2000

# ---- ロギング ----
# debug | info | warn | error
LOG_LEVEL=info
