[Unit]
Description=MOLA Timing Okayama cloud server (WebSocket / API)
After=network.target

[Service]
Type=simple
User=ubuntu
Group=ubuntu
WorkingDirectory=/opt/mola-timing-okayama/repo/server
EnvironmentFile=/opt/mola-timing-okayama/shared/server.env
ExecStart=/usr/bin/node dist/index.js
Restart=on-failure
RestartSec=3
LimitNOFILE=65535

# 安全側
NoNewPrivileges=true
PrivateTmp=true

[Install]
WantedBy=multi-user.target
